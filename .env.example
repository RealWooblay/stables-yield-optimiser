# Solana RPC endpoint (defaults to public mainnet-beta if not set)
# Recommended: use Helius, Triton, or other premium RPC for production
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API key (optional - enables enhanced token metadata and balances)
# Get one at https://helius.dev
VITE_HELIUS_API_KEY=

# Anthropic API key (required for AI intelligence features)
# Get one at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=
